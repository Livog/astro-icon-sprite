{
  "name": "astro-icon-sprite",
  "version": "0.1.0",
  "type": "module",
  "description": "Build-time SVG sprite sheet compilation for Astro, powered by astro-stacks",
  "keywords": ["astro", "svg", "icons", "sprite", "vite-plugin", "astro-integration"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Livog/astro-icon-sprite.git"
  },
  "author": "Livog",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./icon.astro": "./dist/icon.astro",
    "./icon-sprite.astro": "./dist/icon-sprite.astro"
  },
  "files": ["dist"],
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc && cp src/*.astro dist/",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "astro": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "peerDependencies": {
    "astro": ">=4.0.0",
    "astro-stacks": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "astro-stacks": {
      "optional": true
    }
  }
}
